<appbar:AppBarWindow x:Class="Harbor.Shell.TopMenuBar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:appbar="clr-namespace:ManagedShell.AppBar;assembly=ManagedShell.AppBar"
        Title="Harbor Menu Bar"
        AllowsTransparency="True"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent">

    <Grid x:Name="MenuBarRoot" Height="24">
        <!-- Background panel with bottom border -->
        <Border x:Name="BackgroundBorder"
                Background="#CC1E1E1E"
                BorderBrush="#3A3A3A"
                BorderThickness="0,0,0,1" />

        <!-- Content layout -->
        <DockPanel Margin="0,0,0,1">
            <!-- Right side: Clock -->
            <Border DockPanel.Dock="Right"
                    x:Name="ClockContainer"
                    Margin="0,0,12,0"
                    VerticalAlignment="Stretch">
                <TextBlock x:Name="ClockText"
                           VerticalAlignment="Center"
                           Foreground="#FFFFFF"
                           FontFamily="Segoe UI Variable"
                           FontSize="13"
                           FontWeight="Regular" />
            </Border>

            <!-- Control Center chevron (visual placeholder) -->
            <TextBlock DockPanel.Dock="Right"
                       Text="›"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       Foreground="#FFFFFF"
                       FontFamily="Segoe UI Variable"
                       FontSize="13"
                       FontWeight="Regular" />

            <!-- System tray icons -->
            <ItemsControl DockPanel.Dock="Right"
                          x:Name="TrayIconsControl"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="18" Height="18"
                                Margin="4,0"
                                VerticalAlignment="Center"
                                Cursor="Hand"
                                ToolTip="{Binding Title}"
                                MouseLeftButtonUp="TrayIcon_MouseLeftButtonUp"
                                MouseRightButtonUp="TrayIcon_MouseRightButtonUp"
                                MouseEnter="TrayIcon_MouseEnter"
                                MouseLeave="TrayIcon_MouseLeave">
                            <Image Source="{Binding Icon}"
                                   Width="18" Height="18"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Left side: Icon + App Name + Menu Items -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Stretch">
                <!-- Harbor icon placeholder (16x16, 8px left padding) -->
                <Border Width="16" Height="16"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center">
                    <Ellipse Fill="#0078D4" Width="12" Height="12"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </Border>

                <!-- Active app name -->
                <Border x:Name="AppNameItem"
                        Margin="4,2,0,2"
                        CornerRadius="4"
                        Background="Transparent"
                        VerticalAlignment="Stretch"
                        Cursor="Hand">
                    <TextBlock x:Name="AppNameText"
                               VerticalAlignment="Center"
                               Padding="6,0"
                               Foreground="#FFFFFF"
                               FontFamily="Segoe UI Variable"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Text="Harbor" />
                </Border>

                <!-- Placeholder menu items -->
                <Border x:Name="FileMenuItem"
                        Margin="0,2,0,2"
                        CornerRadius="4"
                        Background="Transparent"
                        VerticalAlignment="Stretch"
                        Cursor="Hand">
                    <TextBlock VerticalAlignment="Center"
                               Padding="8,0"
                               Foreground="#80FFFFFF"
                               FontFamily="Segoe UI Variable"
                               FontSize="13"
                               FontWeight="Regular"
                               Text="File" />
                </Border>

                <Border x:Name="EditMenuItem"
                        Margin="0,2,0,2"
                        CornerRadius="4"
                        Background="Transparent"
                        VerticalAlignment="Stretch"
                        Cursor="Hand">
                    <TextBlock VerticalAlignment="Center"
                               Padding="8,0"
                               Foreground="#80FFFFFF"
                               FontFamily="Segoe UI Variable"
                               FontSize="13"
                               FontWeight="Regular"
                               Text="Edit" />
                </Border>

                <Border x:Name="ViewMenuItem"
                        Margin="0,2,0,2"
                        CornerRadius="4"
                        Background="Transparent"
                        VerticalAlignment="Stretch"
                        Cursor="Hand">
                    <TextBlock VerticalAlignment="Center"
                               Padding="8,0"
                               Foreground="#80FFFFFF"
                               FontFamily="Segoe UI Variable"
                               FontSize="13"
                               FontWeight="Regular"
                               Text="View" />
                </Border>
            </StackPanel>
        </DockPanel>
    </Grid>
</appbar:AppBarWindow>
