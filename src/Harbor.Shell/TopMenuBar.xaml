<appbar:AppBarWindow x:Class="Harbor.Shell.TopMenuBar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:appbar="clr-namespace:ManagedShell.AppBar;assembly=ManagedShell.AppBar"
        xmlns:controls="clr-namespace:Harbor.Shell.Controls"
        Title="Harbor Menu Bar"
        AllowsTransparency="True"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent">

    <Grid x:Name="MenuBarRoot" Height="30">
        <!-- Auto-hide trigger zone: 2px tall, invisible, at top edge -->
        <Border x:Name="AutoHideTriggerZone"
                Height="2"
                VerticalAlignment="Top"
                Background="Transparent"
                IsHitTestVisible="True"
                Visibility="Collapsed"
                MouseEnter="TriggerZone_MouseEnter" />

        <!-- Main menu bar container (slides up/down for auto-hide) -->
        <Grid x:Name="MenuBarContainer"
              RenderTransformOrigin="0.5,0"
              MouseEnter="MenuBarContainer_MouseEnter"
              MouseLeave="MenuBarContainer_MouseLeave">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="MenuBarSlideTransform" Y="0" />
            </Grid.RenderTransform>

            <!-- Background panel with bottom border -->
            <Border x:Name="BackgroundBorder"
                    Background="{DynamicResource MenuBarBackground}"
                    BorderBrush="{DynamicResource MenuBarBorderBrush}"
                    BorderThickness="0,0,0,1" />

            <!-- Content layout -->
            <DockPanel Margin="4,0,4,0" VerticalAlignment="Stretch">
                <!-- Right side: Clock -->
                <Border DockPanel.Dock="Right"
                        x:Name="ClockContainer"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        MouseLeftButtonUp="Clock_Click">
                    <TextBlock x:Name="ClockText"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MenuBarTextBrush}"
                               FontFamily="Segoe UI Variable"
                               FontSize="13"
                               FontWeight="Regular">
                        <TextBlock.Effect>

                            <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.3" Color="Black" />
                        </TextBlock.Effect>
                    </TextBlock>
                </Border>

                <!-- Control Center chevron (visual placeholder) -->
                <TextBlock DockPanel.Dock="Right"
                           Text="›"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Foreground="{DynamicResource MenuBarTextBrush}"
                           FontFamily="Segoe UI Variable"
                           FontSize="13"
                           FontWeight="Regular">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.3" Color="Black" />
                    </TextBlock.Effect>
                </TextBlock>

                <!-- System indicator icons (custom vector controls) -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0">
                    <controls:SystemIndicatorIcon x:Name="SafeRemoveIcon"
                                                   Margin="2,0"
                                                   VerticalAlignment="Center"
                                                   Visibility="Collapsed" />
                    <controls:SystemIndicatorIcon x:Name="BluetoothIcon"
                                                   Margin="2,0"
                                                   VerticalAlignment="Center" />
                    <controls:SystemIndicatorIcon x:Name="WiFiIcon"
                                                   Margin="2,0"
                                                   VerticalAlignment="Center" />
                    <controls:SystemIndicatorIcon x:Name="BatteryIcon"
                                                   Margin="2,0"
                                                   VerticalAlignment="Center" />
                    <controls:SystemIndicatorIcon x:Name="VolumeIcon"
                                                   Margin="2,0"
                                                   VerticalAlignment="Center" />
                </StackPanel>

                <!-- System tray icons -->
                <ItemsControl DockPanel.Dock="Right"
                              x:Name="TrayIconsControl"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="18" Height="18"
                                    Margin="4,0"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    ToolTip="{Binding Title}"
                                    MouseLeftButtonUp="TrayIcon_MouseLeftButtonUp"
                                    MouseRightButtonUp="TrayIcon_MouseRightButtonUp"
                                    MouseEnter="TrayIcon_MouseEnter"
                                    MouseLeave="TrayIcon_MouseLeave">
                                <Image Source="{Binding Icon}"
                                       Width="18" Height="18"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.Effect>
                                        <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.3" Color="Black" />
                                    </Image.Effect>
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <!-- Monochrome conversion applied dynamically in code-behind -->
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Left side: Icon + App Name + Menu Items -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- Windows logo — opens system menu on click -->
                    <Border x:Name="WindowsLogoItem"
                            Width="16" Height="16"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            MouseLeftButtonUp="WindowsLogo_Click">
                        <Image Source="Assets/windows-logo.svg" Width="14" Height="14"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>

                    <!-- Active app name -->
                    <Border x:Name="AppNameItem"
                            Margin="4,0,0,0"
                            CornerRadius="4"
                            Background="Transparent"
                            VerticalAlignment="Center"
                            Cursor="Hand">
                        <TextBlock x:Name="AppNameText"
                                   VerticalAlignment="Center"
                                   Padding="6,2"
                                   Foreground="{DynamicResource MenuBarTextBrush}"
                                   FontFamily="Segoe UI Variable"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Text="Harbor">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.3" Color="Black" />
                        </TextBlock.Effect>
                    </TextBlock>
                    </Border>

                    <!-- Dynamic global menu items -->
                    <ItemsControl x:Name="MenuItemsControl"
                                  VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,0"
                                        CornerRadius="4"
                                        Background="Transparent"
                                        VerticalAlignment="Center"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="GlobalMenuItem_Click"
                                        MouseEnter="OnMenuItemMouseEnter"
                                        MouseLeave="OnMenuItemMouseLeave"
                                        MouseLeftButtonDown="OnMenuItemMouseDown">
                                    <TextBlock VerticalAlignment="Center"
                                               Padding="8,2"
                                               Foreground="{DynamicResource MenuBarInactiveTextBrush}"
                                               FontFamily="Segoe UI Variable"
                                               FontSize="13"
                                               FontWeight="Regular"
                                               Text="{Binding Name}">
                                        <TextBlock.Effect>
                                            <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.3" Color="Black" />
                                        </TextBlock.Effect>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Grid>
</appbar:AppBarWindow>
