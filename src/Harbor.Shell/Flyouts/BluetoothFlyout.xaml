<Window x:Class="Harbor.Shell.Flyouts.BluetoothFlyout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bluetooth"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <Border Background="{DynamicResource FlyoutBackground}"
            BorderBrush="{DynamicResource FlyoutBorderBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="16"
            Margin="4"
            MinWidth="280">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" Opacity="0.3" ShadowDepth="4" Direction="270" />
        </Border.Effect>

        <StackPanel>
            <!-- Header -->
            <TextBlock Text="Bluetooth"
                       FontFamily="Segoe UI Variable"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource FlyoutHeaderForeground}"
                       Margin="4,0,0,12" />

            <!-- Toggle row -->
            <Border CornerRadius="8"
                    Padding="8,6"
                    Margin="0,0,0,8"
                    Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Bluetooth"
                               FontFamily="Segoe UI Variable"
                               FontSize="13"
                               Foreground="{DynamicResource FlyoutHeaderForeground}"
                               VerticalAlignment="Center" />

                    <CheckBox x:Name="BluetoothToggle"
                              Grid.Column="1"
                              VerticalAlignment="Center"
                              Checked="BluetoothToggle_Changed"
                              Unchecked="BluetoothToggle_Changed" />
                </Grid>
            </Border>

            <!-- Separator -->
            <Border Height="1"
                    Background="{DynamicResource FlyoutBorderBrush}"
                    Margin="0,0,0,8" />

            <!-- Devices label -->
            <TextBlock x:Name="DevicesLabel"
                       Text="Devices"
                       FontFamily="Segoe UI Variable"
                       FontSize="11"
                       Foreground="{DynamicResource FlyoutSecondaryText}"
                       Margin="4,0,0,6" />

            <!-- No devices message -->
            <TextBlock x:Name="NoDevicesText"
                       Text="No Devices Connected"
                       FontFamily="Segoe UI Variable"
                       FontSize="12"
                       Foreground="{DynamicResource FlyoutSecondaryText}"
                       Margin="4,0,0,8"
                       Visibility="Collapsed" />

            <!-- Connected devices list -->
            <ItemsControl x:Name="DeviceList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="8"
                                Padding="8,6"
                                Margin="0,1"
                                Background="Transparent"
                                MouseEnter="DeviceRow_MouseEnter"
                                MouseLeave="DeviceRow_MouseLeave">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Vertical">
                                    <TextBlock Text="{Binding Name}"
                                               FontFamily="Segoe UI Variable"
                                               FontSize="13"
                                               Foreground="{DynamicResource FlyoutHeaderForeground}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontFamily="Segoe UI Variable"
                                               FontSize="11"
                                               Foreground="{DynamicResource FlyoutSecondaryText}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0}">
                                                <Binding Path="Category" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           Text="Connected"
                                           FontFamily="Segoe UI Variable"
                                           FontSize="11"
                                           Foreground="{DynamicResource FlyoutSecondaryText}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Separator -->
            <Border Height="1"
                    Background="{DynamicResource FlyoutBorderBrush}"
                    Margin="0,8,0,4" />

            <!-- Bluetooth Settings link -->
            <Border CornerRadius="8"
                    Padding="8,6"
                    Cursor="Hand"
                    Background="Transparent"
                    MouseLeftButtonUp="BluetoothSettings_Click"
                    MouseEnter="DeviceRow_MouseEnter"
                    MouseLeave="DeviceRow_MouseLeave">
                <TextBlock Text="Bluetooth Settings..."
                           FontFamily="Segoe UI Variable"
                           FontSize="13"
                           Foreground="{DynamicResource FlyoutHeaderForeground}" />
            </Border>
        </StackPanel>
    </Border>
</Window>
