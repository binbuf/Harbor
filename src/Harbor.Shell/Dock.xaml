<Window x:Class="Harbor.Shell.Dock"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Harbor Dock"
        AllowsTransparency="True"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- Custom tooltip style: rounded pill, 8px above icon -->
        <Style x:Key="DockTooltipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="{DynamicResource DockTooltipBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource DockTooltipForeground}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Placement" Value="Top" />
            <Setter Property="VerticalOffset" Value="-8" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shared icon DataTemplate used by both pinned and running ItemsControls -->
        <DataTemplate x:Key="DockIconTemplate">
            <Grid Width="48" Height="56"
                  Margin="6,0"
                  Cursor="Hand"
                  RenderTransformOrigin="0.5,1.0"
                  MouseLeftButtonDown="DockIcon_MouseLeftButtonDown"
                  MouseLeftButtonUp="DockIcon_MouseLeftButtonUp"
                  MouseRightButtonUp="DockIcon_MouseRightButtonUp"
                  MouseEnter="DockIcon_MouseEnter"
                  MouseLeave="DockIcon_MouseLeave">
                <Grid.ToolTip>
                    <ToolTip Content="{Binding DisplayName}"
                             Style="{StaticResource DockTooltipStyle}" />
                </Grid.ToolTip>
                <ToolTipService.InitialShowDelay>500</ToolTipService.InitialShowDelay>
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="IconScale" ScaleX="1" ScaleY="1" />
                        <TranslateTransform x:Name="IconTranslate" Y="0" />
                    </TransformGroup>
                </Grid.RenderTransform>
                <!-- Application icon -->
                <Image Source="{Binding Icon}"
                       Width="48" Height="48"
                       VerticalAlignment="Top"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <!-- Active indicator dot (visible only when running) -->
                <Ellipse Width="4" Height="4"
                         Fill="{DynamicResource DockActiveDotBrush}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Bottom"
                         Margin="0,0,0,0"
                         Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="DockRoot" Height="96" VerticalAlignment="Bottom">
        <!-- Auto-hide trigger zone: 6px tall, invisible, at bottom edge -->
        <Border x:Name="AutoHideTriggerZone"
                Height="6"
                VerticalAlignment="Bottom"
                Background="Transparent"
                IsHitTestVisible="True"
                MouseEnter="TriggerZone_MouseEnter" />

        <!-- Dock container: centered, auto-width, rounded corners, acrylic background -->
        <Border x:Name="DockContainer"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,0"
                CornerRadius="16,16,0,0"
                Background="{DynamicResource DockBackground}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="1,1,1,0"
                Padding="8,6,8,2"
                ClipToBounds="False"
                RenderTransformOrigin="0.5,1"
                MouseEnter="DockContainer_MouseEnter"
                MouseLeave="DockContainer_MouseLeave"
                MouseMove="DockContainer_MouseMove">
            <Border.RenderTransform>
                <TranslateTransform x:Name="DockSlideTransform" Y="0" />
            </Border.RenderTransform>

            <StackPanel x:Name="DockPanel" Orientation="Horizontal" ClipToBounds="False">
                <!-- Pinned application icons -->
                <ItemsControl x:Name="PinnedIconsControl"
                              VerticalAlignment="Center"
                              ClipToBounds="False"
                              ItemTemplate="{StaticResource DockIconTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- Separator: 1px vertical line between pinned and running sections -->
                <Border x:Name="DockSeparator"
                        Width="1"
                        Height="24"
                        VerticalAlignment="Center"
                        Margin="2,0"
                        Background="{DynamicResource DockSeparatorBrush}"
                        Visibility="Collapsed" />

                <!-- Running (unpinned) application icons -->
                <ItemsControl x:Name="RunningIconsControl"
                              VerticalAlignment="Center"
                              ClipToBounds="False"
                              ItemTemplate="{StaticResource DockIconTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- Trash separator -->
                <Border x:Name="TrashSeparator"
                        Width="1"
                        Height="24"
                        VerticalAlignment="Center"
                        Margin="2,0"
                        Background="{DynamicResource DockSeparatorBrush}" />

                <!-- Trash / Recycle Bin -->
                <Grid x:Name="TrashIcon"
                      Width="48" Height="56"
                      Margin="6,0"
                      Cursor="Hand"
                      RenderTransformOrigin="0.5,1.0"
                      MouseLeftButtonUp="TrashIcon_Click"
                      MouseRightButtonUp="TrashIcon_RightClick"
                      MouseEnter="TrashIcon_MouseEnter"
                      MouseLeave="TrashIcon_MouseLeave">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                            <TranslateTransform Y="0" />
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Grid.ToolTip>
                        <ToolTip Content="Trash"
                                 Style="{StaticResource DockTooltipStyle}" />
                    </Grid.ToolTip>
                    <ToolTipService.InitialShowDelay>500</ToolTipService.InitialShowDelay>
                    <Image x:Name="TrashIconImage"
                           Width="48" Height="48"
                           VerticalAlignment="Top"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
