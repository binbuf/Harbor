<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Top Menu Bar -->
    <SolidColorBrush x:Key="MenuBarBackground" Color="#CCF6F6F6" />
    <SolidColorBrush x:Key="MenuBarBorderBrush" Color="#D1D1D1" />
    <SolidColorBrush x:Key="MenuBarTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="MenuBarInactiveTextBrush" Color="#80FFFFFF" />

    <!-- Dock -->
    <SolidColorBrush x:Key="DockBackground" Color="#D8E1E1E1" />
    <SolidColorBrush x:Key="DockBorderBrush" Color="#14000000" />
    <SolidColorBrush x:Key="DockSeparatorBrush" Color="#1F000000" />
    <SolidColorBrush x:Key="DockActiveDotBrush" Color="#000000" />

    <!-- Dock Tooltip -->
    <SolidColorBrush x:Key="DockTooltipBackground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="DockTooltipForeground" Color="#FFFFFF" />

    <!-- App Switcher -->
    <SolidColorBrush x:Key="AppSwitcherBackground" Color="#D9F6F6F6" />
    <SolidColorBrush x:Key="AppSwitcherForeground" Color="#000000" />
    <SolidColorBrush x:Key="AppSwitcherAccentBrush" Color="#0078D4" />

    <!-- Context Menu (macOS Tahoe) -->
    <SolidColorBrush x:Key="ContextMenuBackground" Color="#E8F6F6F6" />
    <SolidColorBrush x:Key="ContextMenuBorderBrush" Color="#D1D1D1" />
    <SolidColorBrush x:Key="ContextMenuForeground" Color="#000000" />
    <SolidColorBrush x:Key="ContextMenuItemHoverBackground" Color="#200078D4" />
    <SolidColorBrush x:Key="ContextMenuSeparatorBrush" Color="#1F000000" />

    <!-- Calendar Flyout -->
    <SolidColorBrush x:Key="FlyoutBackground" Color="#E8F6F6F6" />
    <SolidColorBrush x:Key="FlyoutBorderBrush" Color="#D1D1D1" />
    <SolidColorBrush x:Key="FlyoutHeaderForeground" Color="#000000" />
    <SolidColorBrush x:Key="CalendarDayHoverBackground" Color="#200078D4" />
    <SolidColorBrush x:Key="CalendarSelectedBackground" Color="#0078D4" />
    <SolidColorBrush x:Key="CalendarTodayBackground" Color="#0078D4" />
    <SolidColorBrush x:Key="CalendarClockForeground" Color="#000000" />
    <SolidColorBrush x:Key="CalendarDateForeground" Color="#CC000000" />
    <SolidColorBrush x:Key="CalendarDayHeaderForeground" Color="#80000000" />
    <SolidColorBrush x:Key="CalendarDayInactiveForeground" Color="#4D000000" />
    <SolidColorBrush x:Key="CalendarTodayForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="CalendarSelectedBorderBrush" Color="#0078D4" />
    <Color x:Key="CalendarRevealBorderColor">#33000000</Color>

    <!-- Settings Window -->
    <SolidColorBrush x:Key="SettingsBackground" Color="#FFF6F6F6" />
    <SolidColorBrush x:Key="SettingsTextBrush" Color="#000000" />
    <SolidColorBrush x:Key="SettingsSidebarBackground" Color="#FFECECEC" />
    <SolidColorBrush x:Key="SettingsSidebarSelectedBackground" Color="#200078D4" />
    <SolidColorBrush x:Key="SettingsSidebarHoverBackground" Color="#14000000" />
    <SolidColorBrush x:Key="SettingsSidebarTextBrush" Color="#000000" />
    <SolidColorBrush x:Key="SettingsContentBackground" Color="#FFF6F6F6" />
    <SolidColorBrush x:Key="SettingsDividerBrush" Color="#1F000000" />
    <SolidColorBrush x:Key="SettingsSecondaryTextBrush" Color="#80000000" />
    <SolidColorBrush x:Key="SettingsToggleAccentBrush" Color="#0078D4" />
    <SolidColorBrush x:Key="SettingsToggleOffBackground" Color="#CCCCCC" />
    <SolidColorBrush x:Key="SettingsCardBackground" Color="#FFFFFFFF" />

    <!-- System Indicator Flyouts -->
    <SolidColorBrush x:Key="FlyoutSliderTrackBackground" Color="#1A000000" />
    <SolidColorBrush x:Key="FlyoutSliderFillBrush" Color="#000000" />
    <SolidColorBrush x:Key="FlyoutSecondaryText" Color="#80000000" />
    <SolidColorBrush x:Key="FlyoutItemHoverBackground" Color="#14000000" />
    <SolidColorBrush x:Key="FlyoutCheckmarkBrush" Color="#0078D4" />

    <!-- Apps Launcher -->
    <SolidColorBrush x:Key="AppsLauncherBackground" Color="#E6F0F0F0" />
    <SolidColorBrush x:Key="AppsLauncherSearchBackground" Color="#1A000000" />
    <SolidColorBrush x:Key="AppsLauncherSearchForeground" Color="#000000" />
    <SolidColorBrush x:Key="AppsLauncherLabelForeground" Color="#000000" />

</ResourceDictionary>
