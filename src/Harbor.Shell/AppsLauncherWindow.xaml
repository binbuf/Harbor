<Window x:Class="Harbor.Shell.AppsLauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Apps"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid>
        <!-- Transparent outer area — click to dismiss -->
        <Border Background="Transparent" />

        <!-- Central content panel with acrylic effect -->
        <Border x:Name="ContentPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="900"
                MaxHeight="700"
                MinWidth="600"
                MinHeight="400"
                CornerRadius="24"
                Background="{DynamicResource AppsLauncherBackground}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="1"
                Padding="24"
                RenderTransformOrigin="0.5,0.5"
                MouseLeftButtonDown="ContentPanel_MouseLeftButtonDown">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="ContentScale" ScaleX="1" ScaleY="1" />
                </TransformGroup>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.3" Color="Black" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <Border Grid.Row="0"
                        CornerRadius="18"
                        Background="{DynamicResource AppsLauncherSearchBackground}"
                        Height="36"
                        MaxWidth="320"
                        Margin="0,0,0,20"
                        Padding="14,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Search icon (magnifying glass) -->
                        <TextBlock Grid.Column="0"
                                   Text="&#x1F50D;"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Foreground="{DynamicResource AppsLauncherSearchForeground}"
                                   Opacity="0.5" />

                        <TextBox x:Name="SearchBox"
                                 Grid.Column="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource AppsLauncherSearchForeground}"
                                 CaretBrush="{DynamicResource AppsLauncherSearchForeground}"
                                 FontSize="14"
                                 FontFamily="Segoe UI Variable"
                                 VerticalContentAlignment="Center"
                                 TextChanged="SearchBox_TextChanged" />

                        <!-- Placeholder text -->
                        <TextBlock x:Name="SearchPlaceholder"
                                   Grid.Column="1"
                                   Text="Search Apps"
                                   FontSize="14"
                                   FontFamily="Segoe UI Variable"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppsLauncherSearchForeground}"
                                   Opacity="0.4"
                                   IsHitTestVisible="False" />
                    </Grid>
                </Border>

                <!-- Scrollable app grid -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              PanningMode="VerticalOnly">
                    <ItemsControl x:Name="AppsGrid">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="110" Height="110"
                                        Margin="4"
                                        CornerRadius="12"
                                        Background="Transparent"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="AppItem_Click"
                                        MouseEnter="AppItem_MouseEnter"
                                        MouseLeave="AppItem_MouseLeave">
                                    <StackPanel VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                        <Image Source="{Binding Icon}"
                                               Width="56" Height="56"
                                               HorizontalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="11"
                                                   FontFamily="Segoe UI Variable"
                                                   Foreground="{DynamicResource AppsLauncherLabelForeground}"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="30"
                                                   HorizontalAlignment="Center"
                                                   Margin="2,4,2,0"
                                                   MaxWidth="100" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
