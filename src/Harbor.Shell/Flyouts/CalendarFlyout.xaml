<Window x:Class="Harbor.Shell.Flyouts.CalendarFlyout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calendar"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Navigation button style (prev/next arrows) -->
        <Style x:Key="CalendarNavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource FlyoutHeaderForeground}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource CalendarDayHoverBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Header button style (month/year label — clickable for zoom) -->
        <Style x:Key="CalendarHeaderButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource FlyoutHeaderForeground}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="4"
                                Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource CalendarDayHoverBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="FlyoutBorder"
            Background="{DynamicResource FlyoutBackground}"
            BorderBrush="{DynamicResource FlyoutBorderBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="16"
            Margin="4"
            Width="320">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="6" Direction="270" />
        </Border.Effect>

        <StackPanel>
            <!-- HEADER: Live clock -->
            <TextBlock x:Name="ClockText"
                       FontFamily="Segoe UI Variable"
                       FontSize="46"
                       FontWeight="Light"
                       Foreground="{DynamicResource CalendarClockForeground}"
                       Margin="4,0,0,0" />

            <!-- Full date -->
            <TextBlock x:Name="DateText"
                       FontFamily="Segoe UI Variable"
                       FontSize="14"
                       Foreground="{DynamicResource CalendarDateForeground}"
                       Margin="4,0,0,8" />

            <!-- Separator -->
            <Border Height="1"
                    Background="{DynamicResource FlyoutBorderBrush}"
                    Margin="0,0,0,8" />

            <!-- CALENDAR CONTENT -->
            <Grid x:Name="CalendarContentHost" ClipToBounds="True" Height="290">

                <!-- DAY VIEW -->
                <Grid x:Name="DayView">
                    <Grid.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Grid.RenderTransform>
                    <Grid.RenderTransformOrigin>0.5,0.5</Grid.RenderTransformOrigin>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Nav bar -->
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="MonthYearButton"
                                Grid.Column="0"
                                Style="{StaticResource CalendarHeaderButton}"
                                Click="MonthYearButton_Click" />

                        <Button x:Name="DayPrevButton"
                                Grid.Column="1"
                                Style="{StaticResource CalendarNavButton}"
                                Click="DayPrev_Click">
                            <Path Data="M8,0 L0,6 L8,12"
                                  Stroke="{DynamicResource FlyoutHeaderForeground}"
                                  StrokeThickness="1.5"
                                  Width="8" Height="12" Stretch="Uniform" />
                        </Button>

                        <Button x:Name="DayNextButton"
                                Grid.Column="2"
                                Style="{StaticResource CalendarNavButton}"
                                Click="DayNext_Click">
                            <Path Data="M0,0 L8,6 L0,12"
                                  Stroke="{DynamicResource FlyoutHeaderForeground}"
                                  StrokeThickness="1.5"
                                  Width="8" Height="12" Stretch="Uniform" />
                        </Button>
                    </Grid>

                    <!-- Day headers (Su Mo Tu ...) -->
                    <UniformGrid x:Name="DayHeaderGrid"
                                 Grid.Row="1"
                                 Rows="1" Columns="7"
                                 Margin="0,0,0,2" />

                    <!-- Day cells 7x6 -->
                    <UniformGrid x:Name="DayGrid"
                                 Grid.Row="2"
                                 Rows="6" Columns="7"
                                 MouseMove="CalendarGrid_MouseMove"
                                 MouseLeave="CalendarGrid_MouseLeave" />
                </Grid>

                <!-- MONTH VIEW -->
                <Grid x:Name="MonthView" Visibility="Collapsed">
                    <Grid.RenderTransform>
                        <ScaleTransform ScaleX="0.6" ScaleY="0.6" />
                    </Grid.RenderTransform>
                    <Grid.RenderTransformOrigin>0.5,0.5</Grid.RenderTransformOrigin>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Nav bar -->
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="YearButton"
                                Grid.Column="0"
                                Style="{StaticResource CalendarHeaderButton}"
                                Click="YearButton_Click" />

                        <Button Grid.Column="1"
                                Style="{StaticResource CalendarNavButton}"
                                Click="MonthViewPrev_Click">
                            <Path Data="M8,0 L0,6 L8,12"
                                  Stroke="{DynamicResource FlyoutHeaderForeground}"
                                  StrokeThickness="1.5"
                                  Width="8" Height="12" Stretch="Uniform" />
                        </Button>

                        <Button Grid.Column="2"
                                Style="{StaticResource CalendarNavButton}"
                                Click="MonthViewNext_Click">
                            <Path Data="M0,0 L8,6 L0,12"
                                  Stroke="{DynamicResource FlyoutHeaderForeground}"
                                  StrokeThickness="1.5"
                                  Width="8" Height="12" Stretch="Uniform" />
                        </Button>
                    </Grid>

                    <!-- Month cells 4x3 -->
                    <UniformGrid x:Name="MonthGrid"
                                 Grid.Row="1"
                                 Rows="3" Columns="4"
                                 MouseMove="CalendarGrid_MouseMove"
                                 MouseLeave="CalendarGrid_MouseLeave" />
                </Grid>

                <!-- DECADE VIEW -->
                <Grid x:Name="DecadeView" Visibility="Collapsed">
                    <Grid.RenderTransform>
                        <ScaleTransform ScaleX="0.6" ScaleY="0.6" />
                    </Grid.RenderTransform>
                    <Grid.RenderTransformOrigin>0.5,0.5</Grid.RenderTransformOrigin>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Nav bar -->
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="DecadeButton"
                                Grid.Column="0"
                                Style="{StaticResource CalendarHeaderButton}"
                                IsHitTestVisible="False"
                                Cursor="Arrow" />

                        <Button Grid.Column="1"
                                Style="{StaticResource CalendarNavButton}"
                                Click="DecadeViewPrev_Click">
                            <Path Data="M8,0 L0,6 L8,12"
                                  Stroke="{DynamicResource FlyoutHeaderForeground}"
                                  StrokeThickness="1.5"
                                  Width="8" Height="12" Stretch="Uniform" />
                        </Button>

                        <Button Grid.Column="2"
                                Style="{StaticResource CalendarNavButton}"
                                Click="DecadeViewNext_Click">
                            <Path Data="M0,0 L8,6 L0,12"
                                  Stroke="{DynamicResource FlyoutHeaderForeground}"
                                  StrokeThickness="1.5"
                                  Width="8" Height="12" Stretch="Uniform" />
                        </Button>
                    </Grid>

                    <!-- Year cells 4x3 -->
                    <UniformGrid x:Name="DecadeGrid"
                                 Grid.Row="1"
                                 Rows="3" Columns="4"
                                 MouseMove="CalendarGrid_MouseMove"
                                 MouseLeave="CalendarGrid_MouseLeave" />
                </Grid>
            </Grid>
        </StackPanel>
    </Border>
</Window>
