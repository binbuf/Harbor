<Window x:Class="Harbor.Shell.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Harbor.Shell"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="False"
        ResizeMode="NoResize">
    <Grid>
        <local:TrafficLightButtons x:Name="TrafficLights" HorizontalAlignment="Left" />
    </Grid>
</Window>
