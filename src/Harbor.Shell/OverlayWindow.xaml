<Window x:Class="Harbor.Shell.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="False"
        ResizeMode="NoResize">
    <Grid>
        <!-- Debug rectangle for visual verification of overlay positioning -->
        <Border x:Name="DebugOverlay"
                Background="#22FF0000"
                BorderBrush="#44FF0000"
                BorderThickness="1"
                IsHitTestVisible="False" />
    </Grid>
</Window>
