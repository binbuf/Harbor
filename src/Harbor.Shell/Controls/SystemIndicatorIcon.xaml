<UserControl x:Class="Harbor.Shell.Controls.SystemIndicatorIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="18" Height="18"
             Cursor="Hand">
    <Border x:Name="HitArea"
            Width="18" Height="18"
            CornerRadius="4"
            Background="Transparent"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            MouseLeftButtonUp="OnClick"
            MouseEnter="OnMouseEnter"
            MouseLeave="OnMouseLeave"
            MouseLeftButtonDown="OnMouseDown">
        <Path x:Name="IconPath"
              Width="16" Height="16"
              Stretch="Uniform"
              Fill="White"
              StrokeThickness="0.8"
              Stroke="White"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <Path.Effect>
                <DropShadowEffect BlurRadius="2" ShadowDepth="0.5" Opacity="0.4" Direction="270" Color="Black" />
            </Path.Effect>
        </Path>
    </Border>
</UserControl>
