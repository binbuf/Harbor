<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Top Menu Bar -->
    <SolidColorBrush x:Key="MenuBarBackground" Color="#CC1E1E1E" />
    <SolidColorBrush x:Key="MenuBarBorderBrush" Color="#3A3A3A" />
    <SolidColorBrush x:Key="MenuBarTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="MenuBarInactiveTextBrush" Color="#80FFFFFF" />

    <!-- Dock -->
    <SolidColorBrush x:Key="DockBackground" Color="#801E1E1E" />
    <SolidColorBrush x:Key="DockBorderBrush" Color="#1FFFFFFF" />
    <SolidColorBrush x:Key="DockSeparatorBrush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="DockActiveDotBrush" Color="#FFFFFF" />

    <!-- Dock Tooltip -->
    <SolidColorBrush x:Key="DockTooltipBackground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="DockTooltipForeground" Color="#FFFFFF" />

</ResourceDictionary>
