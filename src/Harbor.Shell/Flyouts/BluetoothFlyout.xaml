<Window x:Class="Harbor.Shell.Flyouts.BluetoothFlyout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bluetooth"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <Border Background="{DynamicResource FlyoutBackground}"
            BorderBrush="{DynamicResource FlyoutBorderBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="16"
            Margin="4"
            MinWidth="280">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" Opacity="0.3" ShadowDepth="4" Direction="270" />
        </Border.Effect>

        <StackPanel>
            <!-- Header -->
            <TextBlock Text="Bluetooth"
                       FontFamily="Segoe UI Variable"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource FlyoutHeaderForeground}"
                       Margin="4,0,0,12" />

            <!-- Toggle row -->
            <Border CornerRadius="8"
                    Padding="8,6"
                    Margin="0,0,0,8"
                    Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Bluetooth"
                               FontFamily="Segoe UI Variable"
                               FontSize="13"
                               Foreground="{DynamicResource FlyoutHeaderForeground}"
                               VerticalAlignment="Center" />

                    <CheckBox x:Name="BluetoothToggle"
                              Grid.Column="1"
                              VerticalAlignment="Center"
                              Checked="BluetoothToggle_Changed"
                              Unchecked="BluetoothToggle_Changed" />
                </Grid>
            </Border>

            <!-- Separator -->
            <Border Height="1"
                    Background="{DynamicResource FlyoutBorderBrush}"
                    Margin="0,0,0,8" />

            <!-- Devices label — "My Devices" when BT is on -->
            <TextBlock x:Name="DevicesLabel"
                       Text="My Devices"
                       FontFamily="Segoe UI Variable"
                       FontSize="11"
                       Foreground="{DynamicResource FlyoutSecondaryText}"
                       Margin="4,0,0,6" />

            <!-- No devices message — shown when BT on but no connected or recent devices -->
            <TextBlock x:Name="NoDevicesText"
                       Text="No Devices Connected"
                       FontFamily="Segoe UI Variable"
                       FontSize="12"
                       Foreground="{DynamicResource FlyoutSecondaryText}"
                       Margin="4,0,0,8"
                       Visibility="Collapsed" />

            <!-- Connected devices — click to disconnect -->
            <ItemsControl x:Name="ConnectedDeviceList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="8"
                                Padding="8,6"
                                Margin="0,1"
                                Background="Transparent"
                                Cursor="Hand"
                                MouseEnter="DeviceRow_MouseEnter"
                                MouseLeave="DeviceRow_MouseLeave"
                                MouseLeftButtonUp="ConnectedDevice_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontFamily="Segoe UI Variable"
                                           FontSize="13"
                                           Foreground="{DynamicResource FlyoutHeaderForeground}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />

                                <TextBlock Grid.Column="1"
                                           Text="{Binding StatusText}"
                                           FontFamily="Segoe UI Variable"
                                           FontSize="11"
                                           Foreground="{DynamicResource FlyoutSecondaryText}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowStatus}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Recent audio devices section — only shown when there are recent devices -->
            <StackPanel x:Name="RecentSection" Visibility="Collapsed">
                <!-- Thin separator between connected and recent -->
                <Border Height="1"
                        Background="{DynamicResource FlyoutBorderBrush}"
                        Margin="0,4,0,4"
                        Opacity="0.5" />

                <!-- Recently disconnected audio devices — dimmed; click to connect -->
                <ItemsControl x:Name="RecentDeviceList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8"
                                    Padding="8,6"
                                    Margin="0,1"
                                    Background="Transparent"
                                    Opacity="0.6"
                                    Cursor="Hand"
                                    MouseEnter="DeviceRow_MouseEnter"
                                    MouseLeave="DeviceRow_MouseLeave"
                                    MouseLeftButtonUp="RecentDevice_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontFamily="Segoe UI Variable"
                                               FontSize="13"
                                               Foreground="{DynamicResource FlyoutHeaderForeground}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />

                                    <!-- "Connecting..." shown while connection is pending -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding StatusText}"
                                               FontFamily="Segoe UI Variable"
                                               FontSize="11"
                                               Foreground="{DynamicResource FlyoutSecondaryText}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowStatus}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Separator -->
            <Border Height="1"
                    Background="{DynamicResource FlyoutBorderBrush}"
                    Margin="0,8,0,4" />

            <!-- Bluetooth Settings link -->
            <Border CornerRadius="8"
                    Padding="8,6"
                    Cursor="Hand"
                    Background="Transparent"
                    MouseLeftButtonUp="BluetoothSettings_Click"
                    MouseEnter="DeviceRow_MouseEnter"
                    MouseLeave="DeviceRow_MouseLeave">
                <TextBlock Text="Bluetooth Settings..."
                           FontFamily="Segoe UI Variable"
                           FontSize="13"
                           Foreground="{DynamicResource FlyoutHeaderForeground}" />
            </Border>
        </StackPanel>
    </Border>
</Window>
