<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Top Menu Bar -->
    <SolidColorBrush x:Key="MenuBarBackground" Color="#CC1E1E1E" />
    <SolidColorBrush x:Key="MenuBarBorderBrush" Color="#3A3A3A" />
    <SolidColorBrush x:Key="MenuBarTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="MenuBarInactiveTextBrush" Color="#80FFFFFF" />

    <!-- Dock -->
    <SolidColorBrush x:Key="DockBackground" Color="#801E1E1E" />
    <SolidColorBrush x:Key="DockBorderBrush" Color="#1FFFFFFF" />
    <SolidColorBrush x:Key="DockSeparatorBrush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="DockActiveDotBrush" Color="#FFFFFF" />

    <!-- Dock Tooltip -->
    <SolidColorBrush x:Key="DockTooltipBackground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="DockTooltipForeground" Color="#FFFFFF" />

    <!-- App Switcher -->
    <SolidColorBrush x:Key="AppSwitcherBackground" Color="#D91E1E1E" />
    <SolidColorBrush x:Key="AppSwitcherForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AppSwitcherAccentBrush" Color="#0078D4" />

    <!-- Context Menu (macOS Tahoe) -->
    <SolidColorBrush x:Key="ContextMenuBackground" Color="#E81E1E1E" />
    <SolidColorBrush x:Key="ContextMenuBorderBrush" Color="#3A3A3A" />
    <SolidColorBrush x:Key="ContextMenuForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ContextMenuItemHoverBackground" Color="#2DFFFFFF" />
    <SolidColorBrush x:Key="ContextMenuSeparatorBrush" Color="#33FFFFFF" />

    <!-- Calendar Flyout -->
    <SolidColorBrush x:Key="FlyoutBackground" Color="#E81E1E1E" />
    <SolidColorBrush x:Key="FlyoutBorderBrush" Color="#3A3A3A" />
    <SolidColorBrush x:Key="FlyoutHeaderForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="CalendarDayHoverBackground" Color="#2DFFFFFF" />
    <SolidColorBrush x:Key="CalendarSelectedBackground" Color="#0078D4" />
    <SolidColorBrush x:Key="CalendarTodayBackground" Color="#333333" />

    <!-- Settings Window -->
    <SolidColorBrush x:Key="SettingsBackground" Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="SettingsTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SettingsSidebarBackground" Color="#FF171717" />
    <SolidColorBrush x:Key="SettingsSidebarSelectedBackground" Color="#2DFFFFFF" />
    <SolidColorBrush x:Key="SettingsSidebarHoverBackground" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="SettingsSidebarTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SettingsContentBackground" Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="SettingsDividerBrush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="SettingsSecondaryTextBrush" Color="#80FFFFFF" />
    <SolidColorBrush x:Key="SettingsToggleAccentBrush" Color="#0078D4" />
    <SolidColorBrush x:Key="SettingsToggleOffBackground" Color="#555555" />
    <SolidColorBrush x:Key="SettingsCardBackground" Color="#FF2A2A2A" />

    <!-- System Indicator Flyouts -->
    <SolidColorBrush x:Key="FlyoutSliderTrackBackground" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="FlyoutSliderFillBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="FlyoutSecondaryText" Color="#80FFFFFF" />
    <SolidColorBrush x:Key="FlyoutItemHoverBackground" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="FlyoutCheckmarkBrush" Color="#0078D4" />

    <!-- Apps Launcher -->
    <SolidColorBrush x:Key="AppsLauncherBackground" Color="#E61E1E1E" />
    <SolidColorBrush x:Key="AppsLauncherSearchBackground" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="AppsLauncherSearchForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AppsLauncherLabelForeground" Color="#FFFFFF" />

</ResourceDictionary>
