<Window x:Class="Harbor.Shell.AppNavigatorOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="App Navigator"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#0A0A0A"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        KeyDown="OnKeyDown">

    <Grid x:Name="RootGrid">
        <!-- Background dim: animated from 0 to 1 opacity on entry -->
        <Rectangle x:Name="DimOverlay"
                   Fill="#000000"
                   Opacity="0" />

        <!-- Desktop strip: top 100px + 12px top margin -->
        <Border x:Name="DesktopStrip"
                VerticalAlignment="Top"
                Height="100"
                Margin="16,12,16,0"
                Background="#1E1E1E"
                CornerRadius="8"
                Opacity="0.7">
            <ItemsControl x:Name="DesktopList"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Border>

        <!-- Window thumbnail canvas: below desktop strip -->
        <Canvas x:Name="WindowCanvas"
                Margin="0,124,0,0"
                ClipToBounds="True" />
    </Grid>
</Window>
