<Window x:Class="Harbor.Shell.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Harbor Settings"
        Width="700" Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource SettingsBackground}">

    <Window.Resources>
        <!-- Toggle switch style (pill-shaped CheckBox) -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Height" Value="20" />
            <Setter Property="Width" Value="38" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border x:Name="Track"
                                    Width="38" Height="20"
                                    CornerRadius="10"
                                    Background="{DynamicResource SettingsToggleOffBackground}">
                                <Ellipse x:Name="Thumb"
                                         Width="16" Height="16"
                                         Fill="White"
                                         HorizontalAlignment="Left"
                                         Margin="2,0,0,0" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background"
                                        Value="{DynamicResource SettingsToggleAccentBrush}" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar item style -->
        <Style x:Key="SidebarItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource SettingsSidebarTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="4,1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SettingsSidebarHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SettingsSidebarSelectedBackground}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SettingsSidebarBackground}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Settings"
                           FontFamily="Segoe UI Variable"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource SettingsSidebarTextBrush}"
                           Margin="16,16,16,12" />

                <ListBox x:Name="CategoryList"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource SidebarItemStyle}"
                         SelectionChanged="CategoryList_SelectionChanged"
                         Padding="0,0,0,8">
                    <ListBoxItem Content="General" IsSelected="True" />
                    <ListBoxItem Content="Appearance" />
                    <ListBoxItem Content="Dock" />
                    <ListBoxItem Content="Menu Bar" />
                    <ListBoxItem Content="Desktop" />
                    <ListBoxItem Content="About" />
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Divider -->
        <Border Grid.Column="1" Background="{DynamicResource SettingsDividerBrush}" />

        <!-- Content area -->
        <Border Grid.Column="2" Background="{DynamicResource SettingsContentBackground}">
            <Grid>
                <!-- General -->
                <ScrollViewer x:Name="GeneralPanel" VerticalScrollBarVisibility="Auto" Padding="24,20" Visibility="Visible">
                    <StackPanel>
                        <TextBlock Text="General"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SettingsTextBrush}"
                                   Margin="0,0,0,16" />

                        <!-- Replace explorer.exe -->
                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Replace explorer.exe"
                                               Foreground="{DynamicResource SettingsTextBrush}"
                                               FontFamily="Segoe UI Variable" FontSize="13" />
                                    <TextBlock Text="Requires restart to take effect"
                                               Foreground="{DynamicResource SettingsSecondaryTextBrush}"
                                               FontFamily="Segoe UI Variable" FontSize="11"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                                <CheckBox x:Name="ReplaceExplorerToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"
                                          Checked="ReplaceExplorerToggle_Changed"
                                          Unchecked="ReplaceExplorerToggle_Changed" />
                            </Grid>
                        </Border>
                        <!-- Filter app list -->
                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Filter app list"
                                               Foreground="{DynamicResource SettingsTextBrush}"
                                               FontFamily="Segoe UI Variable" FontSize="13" />
                                    <TextBlock Text="Hide utilities, documentation, and uninstallers from the Apps launcher"
                                               Foreground="{DynamicResource SettingsSecondaryTextBrush}"
                                               FontFamily="Segoe UI Variable" FontSize="11"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                                <CheckBox x:Name="FilterAppsFolderToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"
                                          Checked="FilterAppsFolderToggle_Changed"
                                          Unchecked="FilterAppsFolderToggle_Changed" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Appearance -->
                <ScrollViewer x:Name="AppearancePanel" VerticalScrollBarVisibility="Auto" Padding="24,20" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Appearance"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SettingsTextBrush}"
                                   Margin="0,0,0,16" />

                        <!-- Theme -->
                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Theme"
                                           Foreground="{DynamicResource SettingsTextBrush}"
                                           FontFamily="Segoe UI Variable" FontSize="13"
                                           VerticalAlignment="Center" />
                                <ComboBox x:Name="ThemeCombo"
                                          Grid.Column="1"
                                          Width="140"
                                          VerticalAlignment="Center"
                                          SelectionChanged="ThemeCombo_SelectionChanged">
                                    <ComboBoxItem Content="Auto (System)" />
                                    <ComboBoxItem Content="Light" />
                                    <ComboBoxItem Content="Dark" />
                                </ComboBox>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Dock -->
                <ScrollViewer x:Name="DockPanel" VerticalScrollBarVisibility="Auto" Padding="24,20" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Dock"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SettingsTextBrush}"
                                   Margin="0,0,0,16" />

                        <!-- Auto-hide dock -->
                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Automatically hide and show the Dock"
                                               Foreground="{DynamicResource SettingsTextBrush}"
                                               FontFamily="Segoe UI Variable" FontSize="13" />
                                    <TextBlock Text="Dock slides out of view until cursor hits the bottom edge"
                                               Foreground="{DynamicResource SettingsSecondaryTextBrush}"
                                               FontFamily="Segoe UI Variable" FontSize="11"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                                <CheckBox x:Name="AutoHideDockToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"
                                          Checked="AutoHideDockToggle_Changed"
                                          Unchecked="AutoHideDockToggle_Changed" />
                            </Grid>
                        </Border>

                        <!-- Icon size -->
                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock x:Name="IconSizeLabel"
                                           Text="Icon size: 48 px"
                                           Foreground="{DynamicResource SettingsTextBrush}"
                                           FontFamily="Segoe UI Variable" FontSize="13"
                                           Margin="0,0,0,8" />
                                <Slider x:Name="IconSizeSlider"
                                        Minimum="32" Maximum="128"
                                        Width="300" HorizontalAlignment="Left"
                                        IsSnapToTickEnabled="True" TickFrequency="4"
                                        ValueChanged="IconSizeSlider_ValueChanged" />
                            </StackPanel>
                        </Border>

                        <!-- Magnification -->
                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Magnification"
                                               Foreground="{DynamicResource SettingsTextBrush}"
                                               FontFamily="Segoe UI Variable" FontSize="13" />
                                    <TextBlock Text="Fishbowl effect on hover"
                                               Foreground="{DynamicResource SettingsSecondaryTextBrush}"
                                               FontFamily="Segoe UI Variable" FontSize="11"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                                <CheckBox x:Name="MagnificationToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"
                                          Checked="MagnificationToggle_Changed"
                                          Unchecked="MagnificationToggle_Changed" />
                            </Grid>
                        </Border>

                        <!-- Animate opening apps -->
                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Animate opening applications"
                                           Foreground="{DynamicResource SettingsTextBrush}"
                                           FontFamily="Segoe UI Variable" FontSize="13"
                                           VerticalAlignment="Center" />
                                <CheckBox x:Name="AnimateOpeningAppsToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"
                                          Checked="AnimateOpeningAppsToggle_Changed"
                                          Unchecked="AnimateOpeningAppsToggle_Changed" />
                            </Grid>
                        </Border>

                        <!-- Show recent apps -->
                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Show recent applications"
                                           Foreground="{DynamicResource SettingsTextBrush}"
                                           FontFamily="Segoe UI Variable" FontSize="13"
                                           VerticalAlignment="Center" />
                                <CheckBox x:Name="ShowRecentAppsToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"
                                          Checked="ShowRecentAppsToggle_Changed"
                                          Unchecked="ShowRecentAppsToggle_Changed" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Menu Bar -->
                <ScrollViewer x:Name="MenuBarPanel" VerticalScrollBarVisibility="Auto" Padding="24,20" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Menu Bar"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SettingsTextBrush}"
                                   Margin="0,0,0,16" />

                        <!-- Show app menu items -->
                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Show app menu items"
                                               Foreground="{DynamicResource SettingsTextBrush}"
                                               FontFamily="Segoe UI Variable" FontSize="13" />
                                    <TextBlock Text="Display the active app's menus in the menu bar"
                                               Foreground="{DynamicResource SettingsSecondaryTextBrush}"
                                               FontFamily="Segoe UI Variable" FontSize="11"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                                <CheckBox x:Name="ShowAppMenuItemsToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"
                                          Checked="ShowAppMenuItemsToggle_Changed"
                                          Unchecked="ShowAppMenuItemsToggle_Changed" />
                            </Grid>
                        </Border>

                        <!-- Auto-hide menu bar -->
                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Automatically hide and show the menu bar"
                                               Foreground="{DynamicResource SettingsTextBrush}"
                                               FontFamily="Segoe UI Variable" FontSize="13" />
                                    <TextBlock Text="Menu bar slides out of view until cursor hits the top edge"
                                               Foreground="{DynamicResource SettingsSecondaryTextBrush}"
                                               FontFamily="Segoe UI Variable" FontSize="11"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                                <CheckBox x:Name="AutoHideMenuBarToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"
                                          Checked="AutoHideMenuBarToggle_Changed"
                                          Unchecked="AutoHideMenuBarToggle_Changed" />
                            </Grid>
                        </Border>

                        <!-- Menu bar opacity -->
                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock x:Name="MenuBarOpacityLabel"
                                           Text="Menu bar opacity: 80%"
                                           Foreground="{DynamicResource SettingsTextBrush}"
                                           FontFamily="Segoe UI Variable" FontSize="13"
                                           Margin="0,0,0,8" />
                                <Slider x:Name="MenuBarOpacitySlider"
                                        Minimum="0" Maximum="100"
                                        Width="300" HorizontalAlignment="Left"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="MenuBarOpacitySlider_ValueChanged" />
                            </StackPanel>
                        </Border>

                        <!-- Menu bar text color -->
                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Menu bar text color"
                                           Foreground="{DynamicResource SettingsTextBrush}"
                                           FontFamily="Segoe UI Variable" FontSize="13"
                                           VerticalAlignment="Center" />
                                <ComboBox x:Name="MenuBarTextColorCombo"
                                          Grid.Column="1"
                                          Width="160"
                                          VerticalAlignment="Center"
                                          SelectionChanged="MenuBarTextColorCombo_SelectionChanged">
                                    <ComboBoxItem Content="White" />
                                    <ComboBoxItem Content="Black" />
                                    <ComboBoxItem Content="Auto (Dynamic)" />
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Monochrome tray icons -->
                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Monochrome tray icons"
                                               Foreground="{DynamicResource SettingsTextBrush}"
                                               FontFamily="Segoe UI Variable" FontSize="13" />
                                    <TextBlock Text="Force all status icons to black and white"
                                               Foreground="{DynamicResource SettingsSecondaryTextBrush}"
                                               FontFamily="Segoe UI Variable" FontSize="11"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                                <CheckBox x:Name="MonochromeTrayIconsToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"
                                          Checked="MonochromeTrayIconsToggle_Changed"
                                          Unchecked="MonochromeTrayIconsToggle_Changed" />
                            </Grid>
                        </Border>

                        <!-- Clock settings header -->
                        <TextBlock Text="Clock"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SettingsTextBrush}"
                                   Margin="0,8,0,8" />

                        <!-- Show day of week -->
                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Show day of week"
                                           Foreground="{DynamicResource SettingsTextBrush}"
                                           FontFamily="Segoe UI Variable" FontSize="13"
                                           VerticalAlignment="Center" />
                                <CheckBox x:Name="ShowDayOfWeekToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"
                                          Checked="ShowDayOfWeekToggle_Changed"
                                          Unchecked="ShowDayOfWeekToggle_Changed" />
                            </Grid>
                        </Border>

                        <!-- Use 24-hour format -->
                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Use 24-hour format"
                                           Foreground="{DynamicResource SettingsTextBrush}"
                                           FontFamily="Segoe UI Variable" FontSize="13"
                                           VerticalAlignment="Center" />
                                <CheckBox x:Name="Use24HourClockToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"
                                          Checked="Use24HourClockToggle_Changed"
                                          Unchecked="Use24HourClockToggle_Changed" />
                            </Grid>
                        </Border>

                        <!-- Show seconds -->
                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Show seconds"
                                           Foreground="{DynamicResource SettingsTextBrush}"
                                           FontFamily="Segoe UI Variable" FontSize="13"
                                           VerticalAlignment="Center" />
                                <CheckBox x:Name="ShowSecondsToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"
                                          Checked="ShowSecondsToggle_Changed"
                                          Unchecked="ShowSecondsToggle_Changed" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Desktop -->
                <ScrollViewer x:Name="DesktopPanel" VerticalScrollBarVisibility="Auto" Padding="24,20" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Desktop"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SettingsTextBrush}"
                                   Margin="0,0,0,16" />

                        <!-- Show desktop icons -->
                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Show desktop icons"
                                           Foreground="{DynamicResource SettingsTextBrush}"
                                           FontFamily="Segoe UI Variable" FontSize="13"
                                           VerticalAlignment="Center" />
                                <CheckBox x:Name="ShowDesktopIconsToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"
                                          Checked="ShowDesktopIconsToggle_Changed"
                                          Unchecked="ShowDesktopIconsToggle_Changed" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- About -->
                <ScrollViewer x:Name="AboutPanel" VerticalScrollBarVisibility="Auto" Padding="24,20" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="About"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SettingsTextBrush}"
                                   Margin="0,0,0,16" />

                        <Border Background="{DynamicResource SettingsCardBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Harbor"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SettingsTextBrush}"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="A macOS-style desktop shell for Windows"
                                           Foreground="{DynamicResource SettingsSecondaryTextBrush}"
                                           FontFamily="Segoe UI Variable" FontSize="12"
                                           Margin="0,0,0,12" />

                                <TextBlock x:Name="VersionText"
                                           Foreground="{DynamicResource SettingsTextBrush}"
                                           FontFamily="Segoe UI Variable" FontSize="13"
                                           Margin="0,0,0,4" />
                                <TextBlock x:Name="DotNetVersionText"
                                           Foreground="{DynamicResource SettingsSecondaryTextBrush}"
                                           FontFamily="Segoe UI Variable" FontSize="12"
                                           Margin="0,0,0,4" />
                                <TextBlock x:Name="SystemInfoText"
                                           Foreground="{DynamicResource SettingsSecondaryTextBrush}"
                                           FontFamily="Segoe UI Variable" FontSize="12" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
