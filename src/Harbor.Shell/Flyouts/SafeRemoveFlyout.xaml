<Window x:Class="Harbor.Shell.Flyouts.SafeRemoveFlyout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Eject"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <Border Background="{DynamicResource FlyoutBackground}"
            BorderBrush="{DynamicResource FlyoutBorderBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="16"
            Margin="4"
            MinWidth="280">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" Opacity="0.3" ShadowDepth="4" Direction="270" />
        </Border.Effect>

        <StackPanel>
            <!-- Header -->
            <TextBlock Text="Eject"
                       FontFamily="Segoe UI Variable"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource FlyoutHeaderForeground}"
                       Margin="4,0,0,12" />

            <!-- No devices message -->
            <TextBlock x:Name="NoDevicesText"
                       Text="No Devices"
                       FontFamily="Segoe UI Variable"
                       FontSize="12"
                       Foreground="{DynamicResource FlyoutSecondaryText}"
                       Margin="4,0,0,8"
                       Visibility="Collapsed" />

            <!-- Ejectable devices list -->
            <ItemsControl x:Name="DeviceList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="8"
                                Padding="8,6"
                                Margin="0,1"
                                Background="Transparent"
                                Cursor="Hand"
                                MouseLeftButtonUp="DeviceRow_Click"
                                MouseEnter="DeviceRow_MouseEnter"
                                MouseLeave="DeviceRow_MouseLeave">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="{Binding Name}"
                                           FontFamily="Segoe UI Variable"
                                           FontSize="13"
                                           Foreground="{DynamicResource FlyoutHeaderForeground}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding DriveLetter}"
                                           FontFamily="Segoe UI Variable"
                                           FontSize="11"
                                           Foreground="{DynamicResource FlyoutSecondaryText}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DriveLetter}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</Window>
